PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX mh: <https://w3id.org/ontologies-ULL/CO-META#>

SELECT DISTINCT ?metaheuristic ?component ?parameter
WHERE { 
	?metaheuristic a mh:Metaheuristic .
		?metaheuristic mh:isConnectedTo ?component .
	?component a mh:MetaheuristicComponent .
		?component mh:hasParameter ?parameter .
}
ORDER BY ?metaheuristic